# Application Configuration
APP_NAME="Political Communication Platform"
API_V1_PREFIX="/api/v1"
DEBUG=False

# Security
SECRET_KEY="change-this-in-production-min-32-chars"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7
PWD_BCRYPT_ROUNDS=12

# MongoDB
MONGODB_URL="mongodb://localhost:27017"
MONGODB_DB_NAME="political_platform"

# CORS Settings
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000","http://127.0.0.1:3000"]

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# File Upload
MAX_UPLOAD_SIZE_MB=5
ALLOWED_IMAGE_TYPES=["image/jpeg","image/png","image/jpg"]

# Notifications
ENABLE_PUSH_NOTIFICATIONS=False
ENABLE_EMAIL_NOTIFICATIONS=False

# Analytics
SENTIMENT_ANALYSIS_ENABLED=False

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Bedrock / LLM
GPT_MODEL="bedrock/amazon.nova-lite-v1:0"
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_DEFAULT_REGION="us-east-1"
