            "body": {
              "mode": "raw",
              "raw": "{\n  \"start_date\": \"2026-04-01T09:00:00Z\",\n  \"end_date\": \"2026-04-07T18:00:00Z\",\n  \"target_roles\": [\"voter\", \"leader\"]\n}"
            }
          },
          "response": []
