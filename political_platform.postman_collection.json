    {
      "name": "5. Polls",
      "description": "Poll lifecycle. Corporator creates → Publishes → Voters respond → Analytics viewed.",
      "item": [
        {
          "name": "5.1 Create Poll (Corporator)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.poll_id) { pm.environment.set('pollId', json.poll_id); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "url": {"raw": "{{baseUrl}}/polls/", "host": ["{{baseUrl}}"], "path": ["polls", ""]},
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Which infrastructure should be prioritized in 2026?\",\n  \"description\": \"Help us understand which civic issues matter most to you.\",\n  \"poll_type\": \"multiple_choice\",\n  \"options\": [\n    {\"text\": \"Roads & Potholes\", \"description\": \"Road repair and maintenance\"},\n    {\"text\": \"Water Supply\", \"description\": \"Clean water access\"},\n    {\"text\": \"Street Lighting\", \"description\": \"Improve street lights\"},\n    {\"text\": \"Parks & Gardens\", \"description\": \"Maintain public spaces\"}\n  ],\n  \"target_roles\": [\"voter\", \"leader\"],\n  \"is_anonymous\": true,\n  \"is_public\": true,\n  \"show_results\": \"after_voting\"\n}"
            }
          },
          "response": []
        },
        {
          "name": "5.2 List Polls",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/polls/?page=1&page_size=20",
              "host": ["{{baseUrl}}"],
